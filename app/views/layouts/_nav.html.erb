<div class="navbar navbar-inverse navbar-default navbar-fixed-top" role="navigation">
  <div class="container">
    <div class="navbar-header">
      <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <%= link_to root_path, class: 'navbar-brand', style: 'display:inline-flex; align-items:center; gap:6px; padding:8px 8px; margin-top:2px;' do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" style="flex-shrink:0;">
          <rect x="2" y="2" width="28" height="19" rx="3" fill="#2FA4E7"/>
          <polygon points="7,21 13,21 9,28" fill="#2FA4E7"/>
          <polyline points="6,11.5 9.5,11.5 12,5.5 16,17.5 20,7.5 22.5,13.5 26,11.5" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span style="font-size:20px; font-weight:600; letter-spacing:-0.3px; line-height:1;">
          <span style="color:#fff;">Thing</span><span style="color:#2FA4E7;">Speak</span>
        </span>
      <% end %>
    </div>
    <div class="navbar-collapse collapse">
      <ul class="nav navbar-nav">

        <% if current_user %>

          <li class="<%= "active " if @menu == 'channels' %>dropdown">
            <a href="#" class="dropdown-toggle" data-toggle="dropdown"><i class="fa fa-bar-chart"></i> <%=t(:channels)%> <b class="caret"></b></a>
            <ul class="dropdown-menu">
              <li><%= link_to t(:channels_my), channels_path %></li>
              <li><%= link_to t(:watched_channels), watched_channels_path %></li>
              <li><%= link_to t(:channels_public), public_channels_path %></li>
            </ul>
          </li>
        <% else %>
          <li <%= "class=active" if @menu == 'channels' %>>
            <%= link_to public_channels_path do %><i class="fa fa-bar-chart"></i> <%= t(:channels) %><% end %>
          </li>
        <% end %>

        <li><a href="/docs"><i class="fa fa-book"></i> Docs</a></li>

      </ul>
      <ul class="nav navbar-nav navbar-right">

        <% if current_user %>
          <li class="<%= "active " if @menu == 'account' %>dropdown">
            <a href="#" class="dropdown-toggle" data-toggle="dropdown"><i class="fa fa-user-circle"></i> <%= current_user.login %> <b class="caret"></b></a>
            <ul class="dropdown-menu">
              <li><%= link_to account_path do %><i class="fa fa-tachometer fa-fw"></i> <%= t(:myaccount) %><% end %></li>
              <li><%= link_to edit_account_path do %><i class="fa fa-cog fa-fw"></i> <%= t(:account_edit) %><% end %></li>
              <li><%= link_to user_profile_path(current_user.login) do %><i class="fa fa-id-card fa-fw"></i> <%= t(:public_profile) %><% end %></li>
              <li><%= link_to edit_profile_path do %><i class="fa fa-pencil fa-fw"></i> <%= t(:profile_edit) %><% end %></li>
              <li class="divider"></li>
              <li><%= link_to logout_path do %><i class="fa fa-sign-out fa-fw"></i> <%= t(:signout) %><% end %></li>
            </ul>
          </li>
        <% else %>
          <li class="dropdown">
            <a href="#" class="dropdown-toggle" data-toggle="dropdown"><i class="fa fa-user-circle"></i> Account <b class="caret"></b></a>
            <ul class="dropdown-menu">
              <li><%= link_to login_path do %><i class="fa fa-sign-in fa-fw"></i> <%= t(:signin) %><% end %></li>
              <li><%= link_to new_user_registration_path do %><i class="fa fa-user-plus fa-fw"></i> <%= t(:signup) %><% end %></li>
            </ul>
          </li>
        <% end %>

      </ul>
    </div><!--/.nav-collapse -->
  </div>
</div>
